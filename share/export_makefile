CC ?= gcc
AR ?= ar
CFLAGS ?= -Wall -Wextra -std=c99 -I.

SRCS := slist.c slist_while.c dlist.c dlist_while.c tree_bst.c paixu_search.c
OBJS := $(SRCS:.c=.o)
LIB := liblistandtree.a

.PHONY: all clean

all: $(LIB)

$(LIB): $(OBJS)
	$(AR) rcs $@ $^

%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

clean:
	rm -f $(OBJS) $(LIB)
